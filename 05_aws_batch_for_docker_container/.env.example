# Week 5 — AWS Batch local config
# Used by deploy.sh and submit_job.sh (NOT injected into the Batch container).
# The container authenticates via IAM role (surfalytics-lambda-github-role), not these credentials.

# AWS region
AWS_REGION=us-east-1

# S3 bucket (from CloudFormation stack output of surfalytics-raw-csv stack)
S3_BUCKET=surfalytics-raw-csv-180795190369

# Number of GitHub repos to collect
TARGET_ROWS=1000

# Optionally hard-code the AWS account ID (auto-detected from STS if not set)
# AWS_ACCOUNT=180795190369
